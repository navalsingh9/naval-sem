      }
    },
    "seo_keywords": [
      "hospital patient satisfaction SEM",
      "HCAHPS structural equation model",
      "SERVQUAL PLS-SEM",
      "healthcare quality measurement",
      "patient experience analytics",
      "CMS data SEM example",
      "doctor communication satisfaction model"
    ]
  },
  {
    "naval_sem_version": "1.0",
    "case_id": "fintech_adoption_v1",
    "metadata": {
      "title": "Why Fintech Adoption Stalls",
      "subtitle": "The trust barrier model",
      "domain": "fintech_analytics",
      "framework": "UTAUT (Venkatesh et al., 2003) + Trust Extension",
      "citation": "Venkatesh et al. (2003); Gefen et al. (2003)",
      "method": "PLS-SEM",
      "bootstrap_iterations": 5000,
      "target_journals": [
        "Journal of Business Research",
        "Computers in Human Behavior",
        "Electronic Commerce Research and Applications",
        "Journal of Financial Services Marketing"
      ]
    },
    "dataset": {
      "name": "Digital Financial Services Adoption Survey",
      "source": "World Bank Global Findex Database 2021 + CGAP FinTech Survey (Wave 3)",
      "license": "Creative Commons Attribution 4.0 International (CC BY 4.0)",
      "rows": 3212,
      "cols": 28,
      "url": "https://www.worldbank.org/en/publication/globalfindex",
      "file": "findex_fintech_adoption.csv",
      "note": "Filter: adult respondents 18\u201365. Exclude non-smartphone users (reduces to ~3,212 usable). Likert 1\u20135 on all UTAUT constructs."
    },
    "research_question": "Does Performance Expectancy drive fintech adoption directly, or does Institutional Trust mediate \u2014 and does this mediation intensify for first-time digital banking users?",
    "constructs": [
      {
        "id": "PE",
        "label": "Performance Expectancy",
        "type": "reflective",
        "indicators": [
          "pe1_useful",
          "pe2_efficient",
          "pe3_financial_control"
        ]
      },
      {
        "id": "EE",
        "label": "Effort Expectancy",
        "type": "reflective",
        "indicators": [
          "ee1_easy",
          "ee2_clear",
          "ee3_skill"
        ]
      },
      {
        "id": "SI",
        "label": "Social Influence",
        "type": "reflective",
        "indicators": [
          "si1_peers",
          "si2_family",
          "si3_media"
        ]
      },
      {
        "id": "Trust",
        "label": "Institutional Trust",
        "type": "reflective",
        "indicators": [
          "tr1_data_safety",
          "tr2_regulation",
          "tr3_provider_rep"
        ]
      },
      {
        "id": "BI",
        "label": "Behavioral Intention",
        "type": "reflective",
        "indicators": [
          "bi1_plan",
          "bi2_recommend",
          "bi3_continue"
        ]
      }
    ],
    "paths": [
      {
        "from": "PE",
        "to": "Trust",
        "hypothesis": "H1: Perceived usefulness builds institutional trust"
      },
      {
        "from": "EE",
        "to": "BI",
        "hypothesis": "H2: Ease of use directly predicts adoption intention"
      },
      {
        "from": "SI",
        "to": "BI",
        "hypothesis": "H3: Social influence predicts adoption intention"
      },
      {
        "from": "Trust",
        "to": "BI",
        "hypothesis": "H4: Trust is the primary intention driver (expected \u03b2>0.50)"
      },
      {
        "from": "PE",
        "to": "BI",
        "hypothesis": "H5: Direct PE \u2192 BI (expected weak after Trust enters)"
      }
    ],
    "expected_results": {
      "surprise_finding": "Performance Expectancy has weak direct effect on Behavioral Intention (\u03b2=0.17) once Institutional Trust is modelled. Users know the product works \u2014 they don't trust the institution behind it.",
      "paths": [
        {
          "path": "PE \u2192 Trust",
          "beta": 0.41,
          "t": 6.2,
          "p": "<0.001",
          "sig": true,
          "ci": "[0.29, 0.53]"
        },
        {
          "path": "EE \u2192 BI",
          "beta": 0.28,
          "t": 4.3,
          "p": "<0.001",
          "sig": true,
          "ci": "[0.16, 0.40]"
        },
        {
          "path": "SI \u2192 BI",
          "beta": 0.33,
          "t": 5.1,
          "p": "<0.001",
          "sig": true,
          "ci": "[0.21, 0.45]"
        },
        {
          "path": "Trust \u2192 BI",
          "beta": 0.53,
          "t": 8.7,
          "p": "<0.001",
          "sig": true,
          "ci": "[0.42, 0.64]"
        },
        {
          "path": "PE \u2192 BI (direct)",
          "beta": 0.17,
          "t": 2.4,
          "p": "0.017",
          "sig": true,
          "ci": "[0.03, 0.31]"
        }
      ],
      "mediation": {
        "type": "partial",
        "indirect_beta": 0.22,
        "ci": "[0.14, 0.30]",
        "moderator_note": "MGA by first-time vs returning users: trust path stronger for first-time (\u03b2=0.67 vs 0.41)"
      },
      "r_squared": {
        "Behavioral Intention": 0.64,
        "Institutional Trust": 0.17
      },
      "measurement": {
        "min_ave": 0.53,
        "min_cr": 0.77,
        "max_htmt": 0.81
      }
    },
    "seo_keywords": [
      "fintech adoption SEM",
      "UTAUT PLS-SEM",
      "digital banking structural equation model",
      "mobile payment adoption model",
      "fintech trust mediation",
      "SmartPLS UTAUT example",
      "technology acceptance model fintech",
      "financial inclusion SEM"
    ]
  },
  {
    "naval_sem_version": "1.0",
    "case_id": "mooc_completion_v1",
    "metadata": {
      "title": "Why Students Drop MOOCs",
      "subtitle": "The engagement collapse model",
      "domain": "education_analytics",
      "framework": "Technology Acceptance Model (Davis, 1989) + Self-Determination Theory",
      "citation": "Davis (1989); Deci & Ryan (1985); Selim (2007)",
      "method": "PLS-SEM",
      "bootstrap_iterations": 5000,
      "target_journals": [
        "Computers & Education",
        "Internet and Higher Education",
        "Educational Technology Research and Development",
        "British Journal of Educational Technology"
      ]
    },
    "dataset": {
      "name": "Open University Learning Analytics Dataset (OULAD)",
      "source": "Kaggle / Open University UK",
      "license": "CC BY 4.0",
      "rows": 32593,
      "cols": 18,
      "url": "https://www.kaggle.com/datasets/rocki37/open-university-learning-analytics-dataset",
      "file": "studentInfo.csv + studentRegistration.csv + studentAssessment.csv",
      "note": "Merge on id_student + code_module. Aggregate assessment scores \u2192 Perceived Learning Quality proxy. Completion = final_result IN ('Pass','Distinction')."
    },
    "research_question": "Does Perceived Usefulness of a MOOC directly drive completion, or does the effect collapse under Social Belonging and Self-Efficacy \u2014 and which construct is the real dropout lever?",
    "constructs": [
      {
        "id": "PU",
        "label": "Perceived Usefulness",
        "type": "reflective",
        "indicators": [
          "avg_score_week1",
          "engagement_rate_early",
          "module_relevance_proxy"
        ]
      },
      {
        "id": "PEOU",
        "label": "Perceived Ease of Use",
        "type": "reflective",
        "indicators": [
          "vle_clicks_n",
          "activity_diversity",
          "submission_on_time"
        ]
      },
      {
        "id": "SB",
        "label": "Social Belonging",
        "type": "reflective",
        "indicators": [
          "forum_posts",
          "peer_interaction",
          "group_activity"
        ]
      },
      {
        "id": "SE",
        "label": "Self-Efficacy",
        "type": "reflective",
        "indicators": [
          "retry_attempts",
          "early_assessment_score",
          "consistency_index"
        ]
      },
      {
        "id": "Completion",
        "label": "Completion Intention",
        "type": "reflective",
        "indicators": [
          "pass_fail_binary",
          "final_assessment_submitted",
          "dropout_week_r"
        ]
      }
    ],
    "paths": [
      {
        "from": "PU",
        "to": "SE",
        "hypothesis": "H1: Perceived usefulness builds student self-efficacy"
      },
      {
        "from": "PEOU",
        "to": "PU",
        "hypothesis": "H2: Ease of platform use shapes perceived course value"
      },
      {
        "from": "SB",
        "to": "Completion",
        "hypothesis": "H3: Social belonging is the primary completion driver"
      },
      {
        "from": "SE",
        "to": "Completion",
        "hypothesis": "H4: Self-efficacy predicts completion"
      },
      {
        "from": "PU",
        "to": "Completion",
        "hypothesis": "H5: Direct PU effect (expected weak under mediation)"
      }
    ],
    "expected_results": {
      "surprise_finding": "Perceived Usefulness has weak direct effect on Completion (\u03b2=0.14) once Self-Efficacy and Social Belonging enter. Students know the course is valuable. They drop because they feel alone and incompetent, not because the content is irrelevant.",
      "paths": [
        {
          "path": "PEOU \u2192 PU",
          "beta": 0.44,
          "t": 7.1,
          "p": "<0.001",
          "sig": true,
          "ci": "[0.32, 0.56]"
        },
        {
          "path": "PU \u2192 SE",
          "beta": 0.37,
          "t": 5.8,
          "p": "<0.001",
          "sig": true,
          "ci": "[0.25, 0.49]"
        },
        {
          "path": "SB \u2192 Completion",
          "beta": 0.48,
          "t": 8.3,
          "p": "<0.001",
          "sig": true,
          "ci": "[0.37, 0.59]"
        },
        {
          "path": "SE \u2192 Completion",
          "beta": 0.41,
          "t": 6.9,
          "p": "<0.001",
          "sig": true,
          "ci": "[0.30, 0.52]"
