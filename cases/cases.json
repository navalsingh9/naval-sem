[
  {
    "naval_sem_version": "1.0",
    "case_id": "hr_attrition_v1",
    "metadata": {
      "title": "Why Employees Really Quit",
      "subtitle": "The manager trust model",
      "domain": "hr_analytics",
      "framework": "Job Demands-Resources (JD-R)",
      "citation": "Demerouti et al. (2001); Hobfoll COR Theory (1989)",
      "method": "PLS-SEM",
      "bootstrap_iterations": 5000,
      "target_journals": [
        "Journal of Applied Psychology",
        "Personnel Psychology",
        "Journal of Organizational Behavior"
      ]
    },
    "dataset": {
      "name": "IBM HR Analytics Attrition",
      "source": "Kaggle",
      "license": "Open Educational License",
      "rows": 1470,
      "cols": 35,
      "nulls": 0,
      "url": "https://www.kaggle.com/datasets/pavansubhasht/ibm-hr-analytics-attrition-dataset",
      "file": "WA_Fn-UseC_-HR-Employee-Attrition.csv"
    },
    "research_question": "Does Work-Life Balance directly reduce attrition, or does its effect run entirely through Job Satisfaction and Manager Trust?",
    "constructs": [
      {
        "id": "WLB",
        "label": "Work-Life Balance",
        "type": "reflective",
        "indicators": [
          "WorkLifeBalance",
          "OverTime_r",
          "BusinessTravel_r"
        ]
      },
      {
        "id": "JobSat",
        "label": "Job Satisfaction",
        "type": "reflective",
        "indicators": [
          "JobSatisfaction",
          "JobInvolvement",
          "EnvironmentSatisfaction"
        ]
      },
      {
        "id": "MgrTrust",
        "label": "Manager Trust",
        "type": "reflective",
        "indicators": [
          "RelationshipSatisfaction",
          "YearsMgr_n",
          "MgrTrust_proxy"
        ]
      },
      {
        "id": "Intent",
        "label": "Intent to Stay",
        "type": "reflective",
        "indicators": [
          "Attrition_r",
          "YearsComp_n",
          "NumComp_r"
        ]
      }
    ],
    "paths": [
      {
        "from": "WLB",
        "to": "JobSat",
        "hypothesis": "H1: WLB positively predicts Job Satisfaction"
      },
      {
        "from": "JobSat",
        "to": "MgrTrust",
        "hypothesis": "H2: Job Satisfaction positively predicts Manager Trust"
      },
      {
        "from": "MgrTrust",
        "to": "Intent",
        "hypothesis": "H3: Manager Trust is the primary retention driver"
      },
      {
        "from": "WLB",
        "to": "Intent",
        "hypothesis": "H4: Direct WLB effect (expected to be non-significant under mediation)"
      }
    ],
    "expected_results": {
      "surprise_finding": "WLB has NO direct effect on retention once Manager Trust enters the model. All wellness investment bypassing manager quality is structurally misallocated.",
      "paths": [
        {
          "path": "WLB \u2192 JobSat",
          "beta": 0.52,
          "t": 8.34,
          "p": "<0.001",
          "sig": true,
          "ci": "[0.39, 0.64]"
        },
        {
          "path": "JobSat \u2192 MgrTrust",
          "beta": 0.39,
          "t": 5.71,
          "p": "<0.001",
          "sig": true,
          "ci": "[0.26, 0.52]"
        },
        {
          "path": "MgrTrust \u2192 Intent",
          "beta": 0.61,
          "t": 10.2,
          "p": "<0.001",
          "sig": true,
          "ci": "[0.50, 0.72]"
        },
        {
          "path": "WLB \u2192 Intent (direct)",
          "beta": 0.08,
          "t": 1.14,
          "p": "0.254",
          "sig": false,
          "ci": "[-0.06, 0.22]"
        }
      ],
      "mediation": {
        "type": "full",
        "indirect_beta": 0.12,
        "ci": "[0.08, 0.18]"
      },
      "r_squared": {
        "Intent to Stay": 0.58,
        "Manager Trust": 0.15,
        "Job Satisfaction": 0.27
      },
      "measurement": {
        "min_ave": 0.51,
        "min_cr": 0.75,
        "max_htmt": 0.79
      }
    },
    "seo_keywords": [
      "employee attrition SEM",
      "HR analytics structural equation modeling",
      "PLS-SEM attrition",
      "why employees quit study",
      "manager trust retention",
      "JD-R PLS-SEM",
      "SmartPLS HR example",
      "attrition mediation analysis"
    ]
  },
  {
    "naval_sem_version": "1.0",
    "case_id": "brand_trust_v1",
    "metadata": {
      "title": "Why Awareness Doesn't Become Purchase",
      "subtitle": "The brand gap model",
      "domain": "marketing_research",
      "framework": "Aaker Brand Equity Model (1991)",
      "citation": "Aaker (1991); Keller CBBE (1993)",
      "method": "PLS-SEM",
      "bootstrap_iterations": 5000,
      "target_journals": [
        "Journal of Marketing",
        "Journal of the Academy of Marketing Science",
        "International Journal of Research in Marketing"
      ]
    },
    "dataset": {
      "name": "Customer Personality Analysis",
      "source": "Kaggle",
      "license": "CC0 Public Domain",
      "rows": 2240,
      "cols": 29,
      "nulls": 24,
      "url": "https://www.kaggle.com/datasets/imakash3011/customer-personality-analysis",
      "file": "marketing_campaign.csv",
      "note": "TAB-separated. Drop 24 null-Income rows \u2192 2,216 clean rows."
    },
    "research_question": "Why does high brand awareness fail to convert into purchase intent? Does Perceived Quality drive Purchase Intent directly, or only through Brand Trust?",
    "constructs": [
      {
        "id": "Awareness",
        "label": "Brand Awareness",
        "type": "reflective",
        "indicators": [
          "Recency_r",
          "NumWebVisitsMonth",
          "NumCatalogPurchases"
        ]
      },
      {
        "id": "Quality",
        "label": "Perceived Quality",
        "type": "reflective",
        "indicators": [
          "PQ1_premium_spend_ratio",
          "PQ2_cmp3_accept",
          "PQ3_cmp4_accept"
        ]
      },
      {
        "id": "Trust",
        "label": "Brand Trust",
        "type": "reflective",
        "indicators": [
          "BT1_tenure",
          "BT2_complain_r",
          "BT3_response"
        ]
      },
      {
        "id": "Intent",
        "label": "Purchase Intent",
        "type": "reflective",
        "indicators": [
          "PI1_total_purchases",
          "PI2_total_spend",
          "PI3_deals_r"
        ]
      }
    ],
    "paths": [
      {
        "from": "Awareness",
        "to": "Quality",
        "hypothesis": "H1: Awareness shapes quality perception"
      },
      {
        "from": "Quality",
        "to": "Trust",
        "hypothesis": "H2: Quality perception converts to brand trust (expected weak in digital-first contexts)"
      },
      {
        "from": "Trust",
        "to": "Intent",
        "hypothesis": "H3: Brand Trust is the primary purchase driver"
      },
      {
        "from": "Awareness",
        "to": "Intent",
        "hypothesis": "H4: Direct awareness effect (partial mediation test)"
      }
    ],
    "expected_results": {
      "surprise_finding": "Quality \u2192 Trust is weak (\u03b2=0.19). Consumers experience the product positively but it does not crystallise into brand trust. This is the gap Aaker's framework does not diagnose.",
      "paths": [
        {
          "path": "Awareness \u2192 Quality",
          "beta": 0.34,
          "t": 5.82,
          "p": "<0.001",
          "sig": true,
          "ci": "[0.23, 0.46]"
        },
        {
          "path": "Quality \u2192 Trust",
          "beta": 0.19,
          "t": 2.91,
          "p": "0.004",
          "sig": true,
          "ci": "[0.06, 0.32]"
        },
        {
          "path": "Trust \u2192 Intent",
          "beta": 0.61,
          "t": 11.4,
          "p": "<0.001",
          "sig": true,
          "ci": "[0.50, 0.71]"
        },
        {
          "path": "Awareness \u2192 Intent",
          "beta": 0.22,
          "t": 3.47,
          "p": "<0.001",
          "sig": true,
          "ci": "[0.10, 0.34]"
        }
      ],
      "mediation": {
        "type": "partial",
        "indirect_beta": 0.12,
        "ci": "[0.07, 0.18]",
        "note": "Awareness\u2192Intent remains significant: both direct and mediated effects exist"
      },
      "r_squared": {
        "Purchase Intent": 0.54,
        "Brand Trust": 0.18,
        "Perceived Quality": 0.12
      },
      "measurement": {
        "min_ave": 0.52,
        "min_cr": 0.76,
        "max_htmt": 0.78
      }
    },
    "seo_keywords": [
      "brand equity SEM",
      "purchase intention PLS-SEM",
      "Aaker brand equity structural model",
      "brand trust measurement",
      "awareness conversion SEM",
      "SmartPLS marketing example",
      "consumer behavior structural equation modeling"
    ]
  },
  {
    "naval_sem_version": "1.0",
    "case_id": "hospital_satisfaction_v1",
    "metadata": {
      "title": "Why Hospital Ratings Fall",
      "subtitle": "The communication mediation model",
      "domain": "healthcare_analytics",
      "framework": "Modified SERVQUAL (Parasuraman et al., 1988)",
      "citation": "Parasuraman et al. (1988); Zeithaml et al. (1990)",
      "method": "PLS-SEM",
      "bootstrap_iterations": 5000,
      "target_journals": [
        "Health Services Research",
        "Medical Care",
        "BMJ Quality & Safety",
        "Journal of Healthcare Management"
      ]
    },
    "dataset": {
      "name": "HCAHPS Patient Satisfaction Survey",
      "source": "CMS.gov (U.S. Centers for Medicare & Medicaid Services)",
      "license": "U.S. Federal Government Public Domain \u2014 no restrictions",
      "rows": 4800,
      "cols": 32,
      "url": "https://data.cms.gov/provider-data/topics/hospitals/hcahps",
      "file": "HCAHPS-Hospital.csv",
      "note": "Filter HCAHPS_Measure_ID for H_COMP_1, H_COMP_2, H_COMP_4, H_HSP_RATING. Pivot on Facility_ID."
    },
    "research_question": "Does faster staff responsiveness directly improve overall patient satisfaction ratings, or does the effect run through doctor and nurse communication quality?",
    "constructs": [
      {
        "id": "Resp",
        "label": "Responsiveness",
        "type": "reflective",
        "indicators": [
          "H_COMP_4_A_P",
          "H_COMP_4_U_P",
          "H_COMP_7_A_P"
        ]
      },
      {
        "id": "DocComm",
        "label": "Doctor Communication",
        "type": "reflective",
        "indicators": [
          "H_COMP_2_A_P",
          "H_COMP_2_U_P",
          "H_COMP_6_Y_P"
        ]
      },
      {
        "id": "NrsComm",
        "label": "Nurse Communication",
        "type": "reflective",
        "indicators": [
          "H_COMP_1_A_P",
          "H_COMP_1_U_P",
          "H_COMP_5_A_P"
        ]
      },
      {
        "id": "Overall",
        "label": "Overall Satisfaction",
        "type": "reflective",
        "indicators": [
          "H_HSP_RATING_9_10",
          "H_RECMND_DY",
          "H_CLEAN_HSP_A_P"
        ]
      }
    ],
    "paths": [
      {
        "from": "Resp",
        "to": "DocComm",
        "hypothesis": "H1: Responsiveness shapes doctor communication perception"
      },
      {
        "from": "Resp",
        "to": "NrsComm",
        "hypothesis": "H2: Responsiveness shapes nurse communication perception"
      },
      {
        "from": "DocComm",
        "to": "Overall",
        "hypothesis": "H3: Doctor communication drives overall satisfaction"
      },
      {
        "from": "NrsComm",
        "to": "Overall",
        "hypothesis": "H4: Nurse communication drives overall satisfaction"
      },
      {
        "from": "Resp",
        "to": "Overall",
        "hypothesis": "H5: Direct responsiveness effect (expected non-sig after mediation)"
      }
    ],
    "expected_results": {
      "surprise_finding": "Responsiveness \u2192 Overall collapses to non-significance (\u03b2=0.11) when communication constructs enter. Buying faster call systems won't move your star rating.",
      "paths": [
        {
          "path": "Resp \u2192 DocComm",
          "beta": 0.58,
          "t": 9.1,
          "p": "<0.001",
          "sig": true,
          "ci": "[0.46, 0.69]"
        },
        {
          "path": "Resp \u2192 NrsComm",
          "beta": 0.62,
          "t": 10.3,
          "p": "<0.001",
          "sig": true,
          "ci": "[0.51, 0.72]"
        },
        {
          "path": "DocComm \u2192 Overall",
          "beta": 0.43,
          "t": 6.7,
          "p": "<0.001",
          "sig": true,
          "ci": "[0.31, 0.55]"
        },
        {
          "path": "NrsComm \u2192 Overall",
          "beta": 0.38,
          "t": 5.9,
          "p": "<0.001",
          "sig": true,
          "ci": "[0.26, 0.50]"
        },
        {
          "path": "Resp \u2192 Overall (direct)",
          "beta": 0.11,
          "t": 1.6,
          "p": "0.108",
          "sig": false,
          "ci": "[-0.02, 0.25]"
        }
      ],
      "mediation": {
        "type": "full",
        "indirect_beta": 0.47,
        "ci": "[0.36, 0.58]"
      },
      "r_squared": {
